# === Database ===
# Docker ile local geliştirme: docker compose up -d db
DATABASE_URL=postgresql://fenlife:fenlife@localhost:5432/fenlife_analytics

# === Anthropic Claude API ===
# https://console.anthropic.com üzerinden al
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# === Veri dizinleri ===
DATA_DIR=./sample-data
OUTPUT_DIR=./app/report/_output

# === Rapor ayarları ===
MIN_EXAM_COUNT=5              # altında "sınırlı analiz" modu
REPORT_TEMPLATE_PATH=./app/report/templates/fenlife_base.docx

# === CORS ===
FRONTEND_ORIGIN=http://localhost:3000

# === Log ===
LOG_LEVEL=INFO
